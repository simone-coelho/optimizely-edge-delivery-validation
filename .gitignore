# Local / private profiles — keep only profiles/example.json in version control
profiles/*.json
!profiles/example.json

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
*~

# Env / secrets
.env
.env.*
!.env.example
*.pem
*.key
