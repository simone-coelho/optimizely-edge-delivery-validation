# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# Run output (timestamped under the profile's outputDir)
runs/
*/runs/
runs-index.json
*-report.json
edge-validation-report.json
soak-report.json
